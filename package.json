{
  "name": "skill-port",
  "version": "0.1.3",
  "description": "Convert AI coding skills across OpenAI/Codex, Claude Code, and Cursor Skills formats.",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "skill-port": "dist/cli.js"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/lu-zhengda/skill-port.git"
  },
  "bugs": {
    "url": "https://github.com/lu-zhengda/skill-port/issues"
  },
  "homepage": "https://github.com/lu-zhengda/skill-port#readme",
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "SECURITY.md"
  ],
  "engines": {
    "node": ">=20"
  },
  "keywords": [
    "skills",
    "codex",
    "claude",
    "cursor",
    "cli",
    "converter"
  ],
  "scripts": {
    "build": "tsup src/cli.ts src/index.ts --format esm --dts --clean --out-dir dist",
    "dev": "tsx src/cli.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e:live": "tsx scripts/live-e2e.ts",
    "lint": "tsc --noEmit",
    "prepare": "npm run build",
    "prepublishOnly": "npm run lint && npm test && npm run build"
  },
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "js-yaml": "^4.1.1"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^22.15.30",
    "tsup": "^8.5.0",
    "tsx": "^4.20.6",
    "typescript": "^5.8.3",
    "vitest": "^3.2.4"
  }
}
